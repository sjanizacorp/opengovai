# ─────────────────────────────────────────────────────────────────────────────
# OpenGovAI — Environment Configuration
# Copy this file to .env and fill in your values before deploying
# NEVER commit .env to version control
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────────────────────────────
OPENGOVAI_ENV=production
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
OPENGOVAI_SECRET_KEY=changeme-replace-with-strong-random-key

# ── Deployment ────────────────────────────────────────────────────────────────
PORT=3000

# ── AI Provider API Keys (add keys for models you want to scan) ────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=
HUGGINGFACE_TOKEN=
GOOGLE_AI_API_KEY=

# ── Alerting (optional) ───────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
PAGERDUTY_SERVICE_KEY=

# ── Email Alerts (optional) ───────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_TO=security@yourorg.com

# ── Integrations (optional) ───────────────────────────────────────────────────
JIRA_BASE_URL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=AIGSEC

GITHUB_TOKEN=
